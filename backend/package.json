{
  "name": "codenclicks-crm-backend",
  "version": "1.0.0",
  "description": "Enterprise-grade CRM Backend for Code N Clicks IT Solutions",
  "main": "dist/server.js",
  "scripts": {
    "build": "prisma generate && prisma db push && tsc",
    "start": "node dist/server.js",
