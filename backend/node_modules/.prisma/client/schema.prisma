datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
}

enum DealStatus {
  ACTIVE
  WON
  LOST
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  REVIEW
  COMPLETED
  ON_HOLD
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  COMPLETED
}

enum EmployeeStatus {
  ACTIVE
  TERMINATED
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
}

enum LeaveType {
  CASUAL
  SICK
  ANNUAL
  UNPAID
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  UNPAID
  OVERDUE
}

enum ExpenseStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignType {
  EMAIL
  SOCIAL
  ADS
  EVENT
}

enum CampaignStatus {
  PLANNING
  ACTIVE
  COMPLETED
  PAUSED
}

// User & Role-Based Access Control
model User {
  id                String     @id @default(uuid()) @db.VarChar(50)
  email             String     @unique @db.VarChar(191)
  password          String
  firstName         String
  lastName          String
  avatarUrl         String?
  status            UserStatus @default(ACTIVE)
  isVerified        Boolean    @default(false)
  verificationToken String?    @unique @db.VarChar(191)
  resetToken        String?    @unique @db.VarChar(191)
  resetTokenExpires DateTime?
  mfaSecret         String?
  mfaEnabled        Boolean    @default(false)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  roleId String @db.VarChar(50)
  role   Role   @relation(fields: [roleId], references: [id])

  employeeProfile Employee?

  // Relations
  assignedLeads Lead[] @relation("LeadAssignment")
  createdLeads  Lead[] @relation("LeadCreation")
  assignedDeals Deal[] @relation("DealAssignment")
  createdDeals  Deal[] @relation("DealCreation")

  managedProjects    Project[]       @relation("ProjectManager")
  projectMemberships ProjectMember[]

  assignedTasks Task[] @relation("TaskAssignment")
  createdTasks  Task[] @relation("TaskCreation")

  taskComments Comment[]

  assignedTickets  Ticket[]  @relation("TicketAssignee")
  approvedLeaves   Leave[]   @relation("LeaveApprover")
  approvedExpenses Expense[] @relation("ExpenseApprover")
  createdExpenses  Expense[] @relation("ExpenseCreator")

  ownedDocuments Document[] @relation("DocumentOwner")
  createdFolders Folder[]   @relation("FolderCreator")
  hostedMeetings Meeting[]  @relation("MeetingHost")

  sentMessages         Message[]         @relation("SentMessages")
  receivedMessages     Message[]         @relation("ReceivedMessages")
  chatGroupMemberships ChatGroupMember[]
  notifications        Notification[]
  auditLogs            AuditLog[]

  @@index([email])
}

model Role {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  code        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roles RolePermission[]
}

model RolePermission {
  roleId       String @db.VarChar(50)
  permissionId String @db.VarChar(50)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// CRM Module
model Lead {
  id        String       @id @default(uuid()) @db.VarChar(50)
  title     String?
  firstName String
  lastName  String?
  email     String?      @db.VarChar(191)
  phone     String?
  priority  LeadPriority @default(MEDIUM)
  company   String?
  status    LeadStatus   @default(NEW)
  source    String?
  score     Int          @default(0)
  notes     String?      @db.Text
  tags      String? // Stored as JSON or comma-separated string
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  assignedToId String? @db.VarChar(50)
  assignedTo   User?   @relation("LeadAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String  @db.VarChar(50)
  createdBy    User    @relation("LeadCreation", fields: [createdById], references: [id])

  activities Activity[]
  timeline   Timeline[]

  @@index([status])
}

model Organization {
  id        String   @id @default(uuid()) @db.VarChar(50)
  name      String   @unique @db.VarChar(191)
  industry  String?
  website   String?
  phone     String?
  address   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts Contact[]
}

model Contact {
  id        String   @id @default(uuid()) @db.VarChar(50)
  firstName String
  lastName  String
  email     String?  @db.VarChar(191)
  phone     String?
  jobTitle  String?
  notes     String?  @db.Text
  tags      String?
  createdAt DateTime @db.DateTime
  updatedAt DateTime @updatedAt

  organizationId String?       @db.VarChar(50)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  activities Activity[]
  documents  Document[]
}

model Pipeline {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals Deal[]
}

model Deal {
  id          String     @id @default(uuid()) @db.VarChar(50)
  name        String
  value       Decimal    @db.Decimal(12, 2)
  stage       String // e.g. "Qualification", "Proposal", "Negotiation"
  probability Int        @default(10)
  closingDate DateTime?
  status      DealStatus @default(ACTIVE)
  commission  Decimal?   @db.Decimal(10, 2)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  pipelineId   String   @db.VarChar(50)
  pipeline     Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  assignedToId String?  @db.VarChar(50)
  assignedTo   User?    @relation("DealAssignment", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String   @db.VarChar(50)
  createdBy    User     @relation("DealCreation", fields: [createdById], references: [id])

  activities Activity[]

  @@index([stage])
}

// Project & Task Management
model Project {
  id          String        @id @default(uuid()) @db.VarChar(50)
  name        String
  description String?       @db.Text
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Decimal?      @db.Decimal(12, 2)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  clientId  String? @db.VarChar(50)
  client    Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  managerId String? @db.VarChar(50)
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id], onDelete: SetNull)

  members    ProjectMember[]
  tasks      Task[]
  milestones Milestone[]
  activities Activity[]
}

model ProjectMember {
  projectId String  @db.VarChar(50)
  userId    String  @db.VarChar(50)
  role      String? // e.g. Developer, Designer

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Milestone {
  id          String    @id @default(uuid()) @db.VarChar(50)
  name        String
  description String?   @db.Text
  dueDate     DateTime?
  isCompleted Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  projectId String  @db.VarChar(50)
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks     Task[]
}

model Task {
  id          String       @id @default(uuid()) @db.VarChar(50)
  title       String
  description String?      @db.Text
  priority    TaskPriority @default(MEDIUM)
  status      TaskStatus   @default(TODO)
  dueDate     DateTime?
  timeSpent   Int          @default(0) // In minutes
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId   String?    @db.VarChar(50)
  project     Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestoneId String?    @db.VarChar(50)
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  assigneeId  String?    @db.VarChar(50)
  assignee    User?      @relation("TaskAssignment", fields: [assigneeId], references: [id], onDelete: SetNull)
  creatorId   String     @db.VarChar(50)
  createdBy   User       @relation("TaskCreation", fields: [creatorId], references: [id])

  parentTaskId String? @db.VarChar(50)
  parentTask   Task?   @relation("TaskDependency", fields: [parentTaskId], references: [id], onDelete: Restrict, onUpdate: Restrict)
  subtasks     Task[]  @relation("TaskDependency")

  checklist ChecklistItem[]
  comments  Comment[]
  documents Document[]
}

model ChecklistItem {
  id          String   @id @default(uuid()) @db.VarChar(50)
  title       String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())

  taskId String @db.VarChar(50)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid()) @db.VarChar(50)
  content   String   @db.Text
  createdAt DateTime @default(now())

  taskId String @db.VarChar(50)
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId String @db.VarChar(50)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Client Management
model Client {
  id          String   @id @default(uuid()) @db.VarChar(50)
  companyName String   @unique @db.VarChar(191)
  contactName String
  email       String   @unique @db.VarChar(191)
  phone       String?
  website     String?
  status      String   @default("ACTIVE")
  address     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projects Project[]
  invoices Invoice[]
  tickets  Ticket[]
}

// HRMS Module
model Employee {
  id           String         @id @default(uuid()) @db.VarChar(50)
  employeeCode String         @unique @db.VarChar(100)
  joiningDate  DateTime
  salary       Decimal        @db.Decimal(12, 2)
  status       EmployeeStatus @default(ACTIVE)
  bankDetails  String?        @db.Text // Stored JSON string
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  userId        String       @unique @db.VarChar(50)
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  departmentId  String?      @db.VarChar(50)
  department    Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId String?      @db.VarChar(50)
  designation   Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  attendance Attendance[]
  leaves     Leave[]
}

model Department {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
}

model Designation {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employees Employee[]
}

model Attendance {
  id        String           @id @default(uuid()) @db.VarChar(50)
  date      DateTime         @db.Date
  clockIn   DateTime
  clockOut  DateTime?
  status    AttendanceStatus @default(PRESENT)
  ipAddress String?
  createdAt DateTime         @default(now())

  employeeId String   @db.VarChar(50)
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
}

model Leave {
  id        String      @id @default(uuid()) @db.VarChar(50)
  leaveType LeaveType
  startDate DateTime
  endDate   DateTime
  reason    String      @db.Text
  status    LeaveStatus @default(PENDING)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  employeeId   String   @db.VarChar(50)
  employee     Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  approvedById String?  @db.VarChar(50)
  approvedBy   User?    @relation("LeaveApprover", fields: [approvedById], references: [id], onDelete: SetNull)
}

// Support Module
model TicketCategory {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())

  tickets Ticket[]
}

model Ticket {
  id           String         @id @default(uuid()) @db.VarChar(50)
  ticketNumber String         @unique @db.VarChar(100)
  subject      String
  description  String         @db.Text
  priority     TicketPriority @default(MEDIUM)
  status       TicketStatus   @default(OPEN)
  slaDeadline  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  categoryId String?         @db.VarChar(50)
  category   TicketCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  assigneeId String?         @db.VarChar(50)
  assignee   User?           @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  clientId   String          @db.VarChar(50)
  client     Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

// Accounting Module
model Invoice {
  id            String        @id @default(uuid()) @db.VarChar(50)
  invoiceNumber String        @unique @db.VarChar(100)
  issueDate     DateTime
  dueDate       DateTime
  status        InvoiceStatus @default(UNPAID)
  taxRate       Decimal       @default(18.0) @db.Decimal(5, 2)
  discount      Decimal       @default(0.0) @db.Decimal(12, 2)
  subtotal      Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  items         String        @db.Text // JSON list of items: [{description, qty, unitPrice, amount}]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  clientId String    @db.VarChar(50)
  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  payments Payment[]
}

model Payment {
  id            String   @id @default(uuid()) @db.VarChar(50)
  amount        Decimal  @db.Decimal(12, 2)
  paymentDate   DateTime
  paymentMethod String // e.g. "Bank Transfer", "Stripe", "Cash"
  transactionId String?  @unique @db.VarChar(100)
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())

  invoiceId String  @db.VarChar(50)
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String        @id @default(uuid()) @db.VarChar(50)
  amount      Decimal       @db.Decimal(12, 2)
  category    String // e.g. "Software License", "Office Rent"
  date        DateTime
  description String?       @db.Text
  status      ExpenseStatus @default(PENDING)
  receiptUrl  String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  createdById  String  @db.VarChar(50)
  createdBy    User    @relation("ExpenseCreator", fields: [createdById], references: [id])
  approvedById String? @db.VarChar(50)
  approvedBy   User?   @relation("ExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)
}

// Marketing Module
model Campaign {
  id             String         @id @default(uuid()) @db.VarChar(50)
  name           String
  type           CampaignType
  status         CampaignStatus @default(PLANNING)
  budget         Decimal?       @db.Decimal(12, 2)
  revenue        Decimal?       @db.Decimal(12, 2)
  leadsGenerated Int            @default(0)
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

// Knowledge Base
model ArticleCategory {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String   @unique @db.VarChar(100)
  description String?
  createdAt   DateTime @default(now())

  articles Article[]
}

model Article {
  id        String   @id @default(uuid()) @db.VarChar(50)
  title     String
  slug      String   @unique @db.VarChar(191)
  content   String   @db.LongText
  status    String   @default("DRAFT") // e.g. "DRAFT", "PUBLISHED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  categoryId String?          @db.VarChar(50)
  category   ArticleCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// File Management
model Folder {
  id        String   @id @default(uuid()) @db.VarChar(50)
  name      String
  createdAt DateTime @default(now())

  parentId    String?    @db.VarChar(50)
  parent      Folder?    @relation("SubFolders", fields: [parentId], references: [id], onDelete: Cascade)
  subFolders  Folder[]   @relation("SubFolders")
  createdById String     @db.VarChar(50)
  createdBy   User       @relation("FolderCreator", fields: [createdById], references: [id])
  documents   Document[]
}

model Document {
  id          String   @id @default(uuid()) @db.VarChar(50)
  name        String
  fileUrl     String
  fileType    String
  fileSize    Int
  version     Int      @default(1)
  permissions String?  @db.Text // Stored JSON config of read/write roles
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  folderId  String?  @db.VarChar(50)
  folder    Folder?  @relation(fields: [folderId], references: [id], onDelete: Cascade)
  ownerId   String   @db.VarChar(50)
  owner     User     @relation("DocumentOwner", fields: [ownerId], references: [id])
  contactId String?  @db.VarChar(50)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  taskId    String?  @db.VarChar(50)
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}

// Calendar Module
model Meeting {
  id             String   @id @default(uuid()) @db.VarChar(50)
  title          String
  description    String?  @db.Text
  startTime      DateTime
  endTime        DateTime
  type           String   @default("MEETING") // e.g. "CALL", "VIDEO", "MEETING"
  location       String?
  participants   String?  @db.Text // JSON string list of emails
  googleEventId  String?
  outlookEventId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  hostId String @db.VarChar(50)
  host   User   @relation("MeetingHost", fields: [hostId], references: [id])
}

// Chat Module (Socket.io ready)
model ChatGroup {
  id        String   @id @default(uuid()) @db.VarChar(50)
  name      String? // Null for direct messages
  isDirect  Boolean  @default(false)
  createdAt DateTime @default(now())

  members  ChatGroupMember[]
  messages Message[]
}

model ChatGroupMember {
  id       String   @id @default(uuid()) @db.VarChar(50)
  joinedAt DateTime @default(now())

  groupId String    @db.VarChar(50)
  group   ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String    @db.VarChar(50)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
}

model Message {
  id        String   @id @default(uuid()) @db.VarChar(50)
  content   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  groupId    String    @db.VarChar(50)
  group      ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  senderId   String    @db.VarChar(50)
  sender     User      @relation("SentMessages", fields: [senderId], references: [id])
  receiverId String?   @db.VarChar(50)
  receiver   User?     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}

// General System Log & Activities
model Notification {
  id        String   @id @default(uuid()) @db.VarChar(50)
  title     String
  message   String   @db.Text
  type      String   @default("INFO") // e.g. "TASK_ASSIGNED", "LEAD_UPDATE"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  userId String @db.VarChar(50)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id          String   @id @default(uuid()) @db.VarChar(50)
  action      String // e.g. "STAGE_CHANGED", "NOTE_ADDED"
  description String   @db.Text
  createdAt   DateTime @default(now())

  leadId    String?  @db.VarChar(50)
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  dealId    String?  @db.VarChar(50)
  deal      Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  projectId String?  @db.VarChar(50)
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  contactId String?  @db.VarChar(50)
  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Timeline {
  id          String   @id @default(uuid()) @db.VarChar(50)
  title       String
  description String?  @db.Text
  createdAt   DateTime @default(now())

  leadId String @db.VarChar(50)
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid()) @db.VarChar(50)
  action    String // e.g. "LOGIN", "DELETE_USER"
  module    String // e.g. "AUTH", "CRM"
  details   String?  @db.Text // JSON metadata of action
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  userId String @db.VarChar(50)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}
